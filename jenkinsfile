pipeline {
    agent any

    environment {
        DEV_REPO        = 'https://github.com/tejasykadu0911/freeCRMTestApplication'
        TEST_REPO       = 'https://github.com/tejasykadu0911/playwrightFrameworkCart'
        DEV_DIR         = 'freeCRMTestApplication'
        TEST_DIR        = 'playwrightFrameworkCart'
        ALLURE_RESULTS  = "${TEST_DIR}/target/allure-results"
        JAVA_VERSION    = '17'
        MAVEN_OPTS      = '-Xmx1024m'
    }

    tools {
        jdk   "JDK-${JAVA_VERSION}"    // Must match name in Jenkins → Global Tool Configuration
        maven "Maven-3.9"              // Must match name in Jenkins → Global Tool Configuration
    }

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 60, unit: 'MINUTES')
    }

    stages {

        // ─────────────────────────────────────────────
        // STAGE 1: Checkout both repos
        // ─────────────────────────────────────────────
        stage('Checkout Repositories') {
            parallel {
                stage('Checkout Dev App') {
                    steps {
                        echo "Cloning Dev Repo: ${DEV_REPO}"
                        dir("${DEV_DIR}") {
                            git branch: 'main',
                                url: "${DEV_REPO}"
                        }
                    }
                }
                stage('Checkout Test Automation') {
                    steps {
                        echo "Cloning Test Repo: ${TEST_REPO}"
                        dir("${TEST_DIR}") {
                            git branch: 'main',
                                url: "${TEST_REPO}"
                        }
                    }
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 2: Build Dev Application
        // ─────────────────────────────────────────────
        stage('Build Dev Application') {
            steps {
                dir("${DEV_DIR}") {
                    echo 'Building dev application with Maven...'
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 3: Start Dev Application
        // ─────────────────────────────────────────────
        stage('Start Dev Application') {
            steps {
                dir("${DEV_DIR}") {
                    echo 'Starting dev application in background...'
                    sh '''
                        # Start Spring Boot / Java app jar in background
                        # Adjust the jar name pattern to match your actual build output
                        JAR_FILE=$(find target -name "*.jar" -not -name "*sources*" | head -1)

                        if [ -z "$JAR_FILE" ]; then
                            echo "ERROR: No JAR file found in target/. Check your build."
                            exit 1
                        fi

                        echo "Starting JAR: $JAR_FILE"
                        nohup java -jar $JAR_FILE > ../app.log 2>&1 &
                        echo $! > ../app.pid
                        echo "App started with PID: $(cat ../app.pid)"

                        # Wait for app to be ready on port 8080 (adjust if different)
                        echo "Waiting for app to be ready on port 8080..."
                        for i in $(seq 1 30); do
                            if curl -s http://localhost:8080 > /dev/null 2>&1; then
                                echo "App is ready!"
                                break
                            fi
                            echo "Attempt $i/30 - waiting 3 seconds..."
                            sleep 3
                        done
                    '''
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 4: Build Test Automation Framework
        // ─────────────────────────────────────────────
        stage('Build Test Framework') {
            steps {
                dir("${TEST_DIR}") {
                    echo 'Compiling test automation framework...'
                    sh 'mvn clean compile -DskipTests'
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 5: Run Regression Tests
        // ─────────────────────────────────────────────
        stage('Run Regression Tests') {
            steps {
                dir("${TEST_DIR}") {
                    echo 'Running regression suite: testng_regression.xml'
                    sh '''
                        mvn clean test \
                            -DsuiteXmlFile=testng_regression.xml \
                            -Dmaven.test.failure.ignore=true
                    '''
                }
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 6: Publish TestNG / Surefire Results
        // ─────────────────────────────────────────────
        stage('Publish Test Results') {
            steps {
                echo 'Publishing TestNG/Surefire XML results...'
                junit testResults: "${TEST_DIR}/target/surefire-reports/*.xml",
                      allowEmptyResults: true
            }
        }

        // ─────────────────────────────────────────────
        // STAGE 7: Generate Allure Report
        // ─────────────────────────────────────────────
        stage('Generate Allure Report') {
            steps {
                echo 'Generating Allure Report...'
                allure([
                    includeProperties: false,
                    jdk              : '',
                    reportBuildPolicy: 'ALWAYS',
                    results          : [[path: "${ALLURE_RESULTS}"]]
                ])
            }
        }
    }

    // ─────────────────────────────────────────────
    // POST: Cleanup & Notifications
    // ─────────────────────────────────────────────
    post {
        always {
            echo 'Stopping dev application...'
            sh '''
                if [ -f app.pid ]; then
                    PID=$(cat app.pid)
                    kill $PID 2>/dev/null || true
                    rm -f app.pid
                    echo "App with PID $PID stopped."
                else
                    echo "No PID file found, app may not have started."
                fi
            '''

            // Archive surefire reports and app logs
            archiveArtifacts artifacts: "${TEST_DIR}/target/surefire-reports/**/*",
                             allowEmptyArchive: true
            archiveArtifacts artifacts: 'app.log',
                             allowEmptyArchive: true

            // Publish TestNG HTML report
            publishHTML(target: [
                allowMissing         : true,
                alwaysLinkToLastBuild: true,
                keepAll              : true,
                reportDir            : "${TEST_DIR}/target/surefire-reports",
                reportFiles          : 'index.html',
                reportName           : 'TestNG Surefire Report'
            ])
        }

        success {
            echo "✅ Pipeline PASSED — All regression tests completed successfully!"
        }

        failure {
            echo "❌ Pipeline FAILED — Check Allure report and app.log for details."
        }

        unstable {
            echo "⚠️  Pipeline UNSTABLE — Some tests failed. Review Allure and Surefire reports."
        }
    }
}